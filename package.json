{
  "name": "obsidian-getnote-importer",
  "version": "1.0.12",
  "description": "GetNote Importer for Obsidian",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "smoke:getnote": "node scripts/smoke-getnote-api.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "getnote"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "obsidian": "^1.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "preact": "^10.29.2",
    "react": "npm:@preact/compat",
    "react-dom": "npm:@preact/compat"
  }
}
